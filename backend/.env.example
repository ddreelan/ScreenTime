PORT=3000
NODE_ENV=development
# REQUIRED: Replace with a strong random secret (e.g. run: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64
JWT_EXPIRES_IN=7d
DB_PATH=./data/screentime.db
CORS_ORIGIN=http://localhost:3001
LOG_LEVEL=info

# OAuth: Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=com.screentime.app:/oauth2callback

# OAuth: Apple
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CLIENT_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=com.screentime.app:/oauth2callback

# OAuth: Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=com.screentime.app://oauth2callback

# Email verification (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@screentime.app
APP_BASE_URL=http://localhost:3000
